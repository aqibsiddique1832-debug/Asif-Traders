// ============================================
// ASIF TRADERS - Database Schema (SQLite)
// Phase 2: Customer Engagement
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// User Management
// ============================================

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  phone         String    @unique
  gstin         String?
  isPhoneVerified Boolean @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  quoteRequests    QuoteRequest[]
  contactSubmissions ContactSubmission[]
  leadEvents       LeadEvent[]
  orders           Order[]
  addresses        Address[]
  cart            Cart?
  testimonials    Testimonial[]
  otpRequests     OtpRequest[]

  @@index([phone])
  @@index([email])
}

model AdminUser {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  role          String    @default("ADMIN") // SUPER_ADMIN, ADMIN, MANAGER, STAFF
  isActive      Boolean   @default(true)
  is2FAEnabled  Boolean   @default(false)
  twoFASecret   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  // Relations
  quoteRequests QuoteRequest[]  @relation("AssignedQuotes")
  activityLogs  AdminActivityLog[]

  @@index([email])
}

model AdminActivityLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String
  entityType  String?
  entityId    String?
  details     String?  // JSON stored as string in SQLite
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  // Relations
  admin       AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
}

// ============================================
// OTP Authentication (Phase 2)
// ============================================

model OtpRequest {
  id           String   @id @default(uuid())
  phone        String
  otpHash      String   // bcrypt hashed OTP
  expiresAt    DateTime
  attempts     Int      @default(0)
  isVerified   Boolean  @default(false)
  isUsed       Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Relations
  user         User?    @relation(fields: [userId], references: [id])
  userId       String?

  @@index([phone])
  @@index([expiresAt])
}

// ============================================
// Product Management
// ============================================

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  image       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  products    Product[]

  @@index([slug])
  @@index([isActive])
}

model Brand {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logo        String?
  website     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  products    Product[]

  @@index([slug])
  @@index([isActive])
}

model Product {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  description    String?
  features       String   @default("[]")  // JSON array stored as string
  specifications String?  // JSON object stored as string
  unit           String   @default("pieces")
  categoryId     String
  brandId        String?
  isFeatured     Boolean  @default(false)
  isActive       Boolean  @default(true)
  tags           String   @default("[]")  // JSON array stored as string
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  category    Category         @relation(fields: [categoryId], references: [id])
  brand       Brand?          @relation(fields: [brandId], references: [id])
  variants    ProductVariant[]
  images      ProductImage[]

  @@index([slug])
  @@index([categoryId])
  @@index([brandId])
  @@index([isFeatured])
  @@index([isActive])
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String
  size          String
  mrp           Float    @default(0)  // SQLite uses Float for decimal
  sellingPrice  Float    @default(0)
  stock         Int      @default(0)
  sku           String?  @unique
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryLogs InventoryLog[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  quoteItems    QuoteRequestItem[]

  @@unique([productId, size])
  @@index([sku])
}

model ProductImage {
  id          String   @id @default(uuid())
  productId   String
  url         String
  altText     String?
  isPrimary   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  // Relations
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model InventoryLog {
  id          String   @id @default(uuid())
  variantId   String
  change      Int      // positive for add, negative for remove
  reason      String   // INITIAL_STOCK, PURCHASE, SALE, RETURN, ADJUSTMENT, DAMAGED, EXPIRED
  referenceId String?
  notes       String?
  adminId     String?
  createdAt   DateTime @default(now())

  // Relations
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([createdAt])
}

// ============================================
// Cart & Cart Items (Phase 2)
// ============================================

model Cart {
  id        String   @id @default(uuid())
  userId    String?   @unique  // One cart per logged-in user
  sessionId String?   // For guest carts
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([sessionId])
  @@index([userId])
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  variantId String
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
}

// ============================================
// Orders (Phase 2)
// ============================================

model Order {
  id              String    @id @default(uuid())
  orderNumber     String    @unique  // e.g., AT-2026-00001
  userId          String
  status          String    @default("PENDING") // PENDING, CONFIRMED, PROCESSING, OUT_FOR_DELIVERY, DELIVERED, CANCELLED
  subtotal        Float     @default(0)
  gstAmount       Float     @default(0)
  deliveryCharge  Float     @default(0)
  totalAmount     Float     @default(0)
  deliveryAddress String    // JSON stored as string
  paymentStatus   String    @default("UNPAID") // UNPAID, PAID, PARTIAL, REFUNDED
  paymentMethod   String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id                  String   @id @default(uuid())
  orderId             String
  variantId           String?
  productNameSnapshot  String
  variantSizeSnapshot  String?
  quantity            Int
  unitPriceSnapshot   Float
  gstPercentSnapshot   Float    @default(18)  // Default 18% GST
  lineTotal           Float
  createdAt           DateTime @default(now())

  // Relations
  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// ============================================
// Addresses (Phase 2)
// ============================================

model Address {
  id          String   @id @default(uuid())
  userId      String
  label       String   // e.g., "Site Office", "Home"
  fullAddress String
  landmark    String?
  pincode     String
  city        String
  state       String   @default("Maharashtra")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// Quote & Order Management
// ============================================

model QuoteRequest {
  id              String    @id @default(uuid())
  referenceNo     String    @unique  // QT + timestamp
  userId          String?
  userName        String
  userPhone       String
  userEmail       String?
  gstin           String?
  notes           String?
  status          String    @default("PENDING") // PENDING, REVIEWING, QUOTED, ACCEPTED, REJECTED, EXPIRED, CONVERTED
  assignedToId    String?
  totalAmount     Float?
  validUntil      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user       User?        @relation(fields: [userId], references: [id])
  assignedTo AdminUser?    @relation("AssignedQuotes", fields: [assignedToId], references: [id])
  items      QuoteRequestItem[]
  events     QuoteEvent[]

  @@index([referenceNo])
  @@index([status])
  @@index([createdAt])
  @@index([userPhone])
}

model QuoteRequestItem {
  id            String   @id @default(uuid())
  quoteId       String
  productId     String?
  variantId     String?
  productName   String   // Store name in case product is deleted
  variantSize   String?
  quantity      Int
  unit          String?
  notes         String?
  createdAt     DateTime @default(now())

  // Relations
  quote         QuoteRequest @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([quoteId])
}

model QuoteEvent {
  id          String   @id @default(uuid())
  quoteId     String
  eventType   String
  oldStatus   String?
  newStatus   String?
  notes       String?
  adminId     String?
  createdAt   DateTime @default(now())

  // Relations
  quote       QuoteRequest @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

// ============================================
// Contact & Feedback
// ============================================

model ContactSubmission {
  id           String   @id @default(uuid())
  userId       String?
  name         String
  phone        String
  email        String?
  subject      String?
  message      String
  status       String   @default("NEW") // NEW, IN_PROGRESS, RESOLVED, CLOSED
  assignedToId String?
  response     String?
  respondedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user       User?       @relation(fields: [userId], references: [id])
  leadEvents LeadEvent[]

  @@index([status])
  @@index([createdAt])
}

model Testimonial {
  id            String   @id @default(uuid())
  customerName  String
  companyName   String?
  location      String?
  rating        Int      @default(5)
  content       String
  image         String?
  isApproved    Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user User? @relation(fields: [userId], references: [id])
  userId String?

  @@index([isApproved])
  @@index([isFeatured])
}

// ============================================
// Lead Tracking
// ============================================

model LeadEvent {
  id                String   @id @default(uuid())
  userId            String?
  eventType         String   // PAGE_VIEW, PRODUCT_VIEW, CATEGORY_VIEW, SEARCH, ADD_TO_CART, REMOVE_FROM_CART, QUOTE_START, QUOTE_SUBMIT, CONTACT_SUBMIT, CALL_CLICK, WHATSAPP_CLICK, FACEBOOK_CLICK, INSTAGRAM_CLICK, MAP_CLICK, OTP_REQUEST, OTP_VERIFY, ORDER_PLACED, ORDER_CONFIRMED
  source            String?
  sourceUrl         String?
  metadata          String?  // JSON stored as string
  ipAddress         String?
  userAgent         String?
  contactSubmissionId String?
  createdAt         DateTime @default(now())

  // Relations
  user              User?              @relation(fields: [userId], references: [id])
  contactSubmission ContactSubmission? @relation(fields: [contactSubmissionId], references: [id])

  @@index([eventType])
  @@index([createdAt])
  @@index([userId])
}

// ============================================
// Settings & Configuration
// ============================================

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   // JSON stored as string in SQLite
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}
